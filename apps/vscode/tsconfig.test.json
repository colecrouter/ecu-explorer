{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"composite": true,
		"types": [
			"vitest/globals",
			"node",
			"@types/vscode",
			"@types/vscode-webview"
		]
	},
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"exclude": [
		"src/webview/main.ts",
		"src/webview/chart-main.ts",
		"src/webview/live-data.ts",
		"./**/*.svelte.test.ts",
		"./**/*.svelte.spec.ts",
		"node_modules/**"
	]
}
